<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FlexPass Hub - Treine onde quiser</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; }
    .hero-bg { background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.9)), url('https://source.unsplash.com/random/1920x1080/?gym') center/cover; }
  </style>
</head>
<body class="bg-zinc-950 text-white">

  <!-- Navbar -->
  <nav class="bg-black border-b border-zinc-800 fixed w-full z-50">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-cyan-400">FlexPass <span class="text-white">Hub</span></h1>
      <div class="flex gap-8">
        <a href="#" class="hover:text-cyan-400 transition">Planos</a>
        <a href="#" class="hover:text-cyan-400 transition">Academias</a>
        <a href="#" class="hover:text-cyan-400 transition">Para Empresas</a>
        <button onclick="showLogin()" class="bg-cyan-500 text-black px-6 py-2 rounded-xl font-semibold hover:bg-cyan-400">Entrar</button>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero-bg h-screen flex items-center pt-20">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-6xl md:text-7xl font-bold leading-tight mb-6">
        Treine onde <span class="text-cyan-400">quiser</span>.<br>
        Pague pelo que <span class="text-cyan-400">usar</span>.
      </h1>
      <p class="text-xl text-zinc-300 mb-10 max-w-2xl mx-auto">
        Assinatura flexível para academias de bairro. Check-in controlado e liberdade total.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button onclick="goToPlanos()" class="bg-cyan-500 text-black px-10 py-4 rounded-2xl text-xl font-semibold hover:bg-cyan-400">
          Escolher Plano
        </button>
        <button onclick="showDemo()" class="border border-white/50 px-10 py-4 rounded-2xl text-xl hover:bg-white/10">
          Ver Demonstração
        </button>
      </div>
    </div>
  </section>

  <!-- Planos -->
  <section id="planos" class="py-20 bg-zinc-900">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center mb-12">Escolha seu Plano</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-zinc-800 p-8 rounded-3xl border border-zinc-700 hover:border-cyan-400 transition">
          <h3 class="text-2xl font-bold">Start</h3>
          <p class="text-5xl font-bold mt-4">R$99<span class="text-base font-normal">/mês</span></p>
          <ul class="mt-8 space-y-3">
            <li>✓ 8 acessos por 30 dias</li>
            <li>✓ Academias de bairro</li>
          </ul>
          <button onclick="simularPagamento(99)" class="w-full mt-10 bg-zinc-700 hover:bg-zinc-600 py-4 rounded-2xl">Assinar</button>
        </div>

        <div class="bg-gradient-to-b from-cyan-500 to-cyan-600 p-8 rounded-3xl text-black scale-105 shadow-2xl">
          <div class="text-center mb-4">
            <span class="bg-black text-white text-sm px-4 py-1 rounded-full">Mais Popular</span>
          </div>
          <h3 class="text-3xl font-bold">Pro</h3>
          <p class="text-6xl font-bold mt-4">R$139<span class="text-base font-normal">/mês</span></p>
          <ul class="mt-8 space-y-3">
            <li>✓ 12 acessos por 30 dias</li>
            <li>✓ Prioridade no check-in</li>
            <li>✓ Suporte premium</li>
          </ul>
          <button onclick="simularPagamento(139)" class="w-full mt-10 bg-black text-white py-4 rounded-2xl font-bold">Assinar com Mercado Pago</button>
        </div>

        <div class="bg-zinc-800 p-8 rounded-3xl border border-zinc-700 hover:border-cyan-400 transition">
          <h3 class="text-2xl font-bold">Elite</h3>
          <p class="text-5xl font-bold mt-4">R$169<span class="text-base font-normal">/mês</span></p>
          <ul class="mt-8 space-y-3">
            <li>✓ 16 acessos por 30 dias</li>
            <li>✓ Todas as academias</li>
          </ul>
          <button onclick="simularPagamento(169)" class="w-full mt-10 bg-zinc-700 hover:bg-zinc-600 py-4 rounded-2xl">Assinar</button>
        </div>
      </div>
    </div>
  </section>

  <script>
    function simularPagamento(preco) {
      alert(`✅ Redirecionando para Mercado Pago...\n\nPlano selecionado: R$${preco}/mês\n\n(Simulação - Em produção usaria integração real)`);
    }

    function showLogin() {
      alert("🔑 Login Demo:\n\nAluno: aluno@flexpass.com / 123456\nProprietário: academia@flexpass.com / 123456");
    }

    function showDemo() {
      alert("📱 Bem-vindo ao FlexPass Hub!\n\nEste é um protótipo funcional em HTML.");
    }

    function goToPlanos() {
      document.getElementById('planos').scrollIntoView({ behavior: 'smooth' });
    }
  </script>
</body>
</html>
