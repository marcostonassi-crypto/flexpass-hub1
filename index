<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FlexPass Hub - Treine onde quiser</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body { font-family: system-ui, -apple-system, sans-serif; }
    .hero-bg {
      background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.9)), 
                  url('https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1920') center/cover no-repeat;
    }
    .card-hover:hover { transform: translateY(-8px); transition: all 0.3s; }
  </style>
</head>
<body class="bg-zinc-950 text-white">

  <!-- Navbar -->
  <nav class="bg-black/80 backdrop-blur-md fixed w-full z-50 border-b border-zinc-800">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-cyan-500 rounded-xl flex items-center justify-center text-black font-bold text-xl">H</div>
        <h1 class="text-2xl font-bold tracking-tight">FLEXPASS<span class="text-cyan-400">-HUB</span></h1>
      </div>
      <div class="hidden md:flex gap-8 text-sm">
        <a href="#" class="hover:text-cyan-400">Academias</a>
        <a href="#" class="hover:text-cyan-400">Planos</a>
        <a href="#" class="hover:text-cyan-400">Para Empresas</a>
      </div>
      <button onclick="alert('Login Demo:\n\nAluno: aluno@flexpass.com\nSenha: 123456')" 
              class="bg-white text-black px-6 py-2.5 rounded-2xl font-semibold hover:bg-cyan-400 hover:text-black transition">
        Entrar
      </button>
    </div>
  </nav>

  <div class="pt-20">
    <!-- Hero + Dashboard -->
    <div class="hero-bg min-h-screen flex items-center">
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
        
        <!-- Left Side -->
        <div class="space-y-8">
          <h1 class="text-6xl md:text-7xl font-bold leading-tight">
            TREINE ONDE<br>QUISER.<br>
            <span class="text-cyan-400">PAGUE PELO QUE USAR.</span>
          </h1>
          <p class="text-xl text-zinc-300 max-w-lg">
            Assinatura mensal para academias de bairro com check-in controlado.
          </p>
          <div class="flex flex-wrap gap-4">
            <button onclick="alert('Redirecionando para escolha de planos...')" 
                    class="bg-cyan-500 text-black px-10 py-4 rounded-2xl font-semibold text-lg flex items-center gap-3 hover:bg-cyan-400">
              <i class="fas fa-rocket"></i> ESCOLHER PLANO
            </button>
            <button onclick="alert('Demo em desenvolvimento...')" 
                    class="border border-white/50 px-8 py-4 rounded-2xl font-semibold flex items-center gap-3 hover:bg-white/10">
              <i class="fas fa-play"></i> VER DEMO
            </button>
          </div>
        </div>

        <!-- Right Side - Mock Dashboard -->
        <div class="bg-zinc-900/90 backdrop-blur-xl rounded-3xl p-6 border border-zinc-700 shadow-2xl">
          <div class="flex justify-between items-center mb-6">
            <div>
              <p class="text-sm text-zinc-400">Olá, Lucas! 👋</p>
              <p class="font-semibold">Bora treinar hoje?</p>
            </div>
            <div class="w-10 h-10 bg-zinc-700 rounded-full overflow-hidden">
              <img src="https://i.pravatar.cc/128?u=lucas" alt="Perfil" class="w-full h-full object-cover">
            </div>
          </div>

          <div class="bg-zinc-800 rounded-2xl p-6 mb-6">
            <div class="flex justify-between">
              <div>
                <p class="text-cyan-400 text-sm font-medium">SEU PLANO • PRO</p>
                <p class="text-5xl font-bold mt-2">12 <span class="text-2xl text-zinc-400">/ 30</span></p>
                <p class="text-sm text-zinc-400">Check-ins restantes</p>
              </div>
              <div class="text-right">
                <div class="w-20 h-20 border-4 border-cyan-400 rounded-full flex items-center justify-center mx-auto">
                  <span class="text-3xl font-bold text-cyan-400">12</span>
                </div>
                <p class="text-xs mt-2">de 30</p>
              </div>
            </div>
          </div>

          <button onclick="alert('📱 Simulando Check-in via QR Code...')" 
                  class="w-full bg-cyan-500 hover:bg-cyan-400 text-black font-bold py-5 rounded-2xl text-lg flex items-center justify-center gap-3">
            <i class="fas fa-qrcode"></i> ESCANEAR QR CODE
          </button>

          <div class="mt-8">
            <p class="text-sm text-zinc-400 mb-4">Academias próximas</p>
            <div class="space-y-4">
              <div class="flex gap-4 bg-zinc-800 p-4 rounded-2xl">
                <div class="w-16 h-16 bg-zinc-700 rounded-xl"></div>
                <div class="flex-1">
                  <p class="font-semibold">Iron Fit - Centro</p>
                  <p class="text-sm text-zinc-400">450m • Aberta agora</p>
                </div>
                <span class="text-emerald-400 text-xs self-start px-3 py-1 bg-emerald-900/50 rounded-full">ABERTA</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Planos -->
    <div class="py-20 bg-zinc-900">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-4xl font-bold text-center mb-4">Escolha seu Plano</h2>
        <p class="text-center text-zinc-400 mb-12">Ciclo de 30 dias • 1 check-in por dia</p>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Start -->
          <div class="bg-zinc-800 rounded-3xl p-8 card-hover">
            <h3 class="text-2xl font-bold">START</h3>
            <p class="text-6xl font-bold mt-6">R$99<span class="text-base font-normal text-zinc-400">/mês</span></p>
            <ul class="mt-10 space-y-4">
              <li class="flex items-center gap-3"><i class="fas fa-check text-cyan-400"></i> 8 acessos por ciclo</li>
              <li class="flex items-center gap-3"><i class="fas fa-check text-cyan-400"></i> Academias de bairro</li>
            </ul>
            <button onclick="alert('Plano Start selecionado!')" class="w-full mt-12 bg-zinc-700 hover:bg-zinc-600 py-4 rounded-2xl">Escolher</button>
          </div>

          <!-- Pro -->
          <div class="bg-gradient-to-br from-cyan-500 to-cyan-600 text-black rounded-3xl p-8 card-hover relative scale-105 shadow-2xl">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-6 py-1 rounded-full">MAIS POPULAR</div>
            <h3 class="text-3xl font-bold">PRO</h3>
            <p class="text-6xl font-bold mt-6">R$139<span class="text-base font-normal opacity-75">/mês</span></p>
            <ul class="mt-10 space-y-4">
              <li class="flex items-center gap-3"><i class="fas fa-check"></i> 12 acessos por ciclo</li>
              <li class="flex items-center gap-3"><i class="fas fa-check"></i> Prioridade</li>
              <li class="flex items-center gap-3"><i class="fas fa-check"></i> Suporte premium</li>
            </ul>
            <button onclick="alert('Redirecionando para Mercado Pago...')" class="w-full mt-12 bg-black text-white py-4 rounded-2xl font-bold">Assinar com Mercado Pago</button>
          </div>

          <!-- Max -->
          <div class="bg-zinc-800 rounded-3xl p-8 card-hover">
            <h3 class="text-2xl font-bold">MAX</h3>
            <p class="text-6xl font-bold mt-6">R$199<span class="text-base font-normal text-zinc-400">/mês</span></p>
            <ul class="mt-10 space-y-4">
              <li class="flex items-center gap-3"><i class="fas fa-check text-cyan-400"></i> Acessos ilimitados</li>
              <li class="flex items-center gap-3"><i class="fas fa-check text-cyan-400"></i> Todas as academias</li>
            </ul>
            <button onclick="alert('Plano Max selecionado!')" class="w-full mt-12 bg-zinc-700 hover:bg-zinc-600 py-4 rounded-2xl">Escolher</button>
          </div>
        </div>
      </div>
    </div>
  </div>

</body>
